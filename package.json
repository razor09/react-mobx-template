{
  "name": "react-mobx-template",
  "scripts": {
    "start": "webpack serve --config webpack/config.ts --progress --mode=development --name=local",
    "start:remote": "webpack serve --config webpack/config.ts --progress --mode=development",
    "build": "webpack --config webpack/config.ts --progress --mode=production",
    "serve": "ts-node tools/scripts/server.ts",
    "clear": "rm -rf dist node_modules package-lock.json public/mockServiceWorker.js && npm install",
    "clear:up": "rm -rf dist node_modules public/mockServiceWorker.js && npm ci",
    "lint": "prettier --write '{public,src,tools,webpack}/**/*.{js,ts,tsx}'",
    "lint:staged": "npm run lint && git add --all",
    "generate:component": "ts-node tools/codegen/scripts/component.ts",
    "generate:store": "ts-node tools/codegen/scripts/store.ts",
    "generate:mocks": "ts-node tools/codegen/scripts/mocks.ts",
    "postinstall": "npm run lint"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "pre-commit": {
    "run": "lint:staged"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "dependencies": {
    "classnames": "2.3.2",
    "mobx": "6.7.0",
    "mobx-react": "7.6.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.4.3",
    "react-transition-group": "4.4.5"
  },
  "devDependencies": {
    "@types/http-server": "0.12.1",
    "@types/node": "18.11.9",
    "@types/react": "18.0.25",
    "@types/react-dom": "18.0.9",
    "@types/react-transition-group": "4.4.5",
    "css-loader": "6.7.2",
    "css-minimizer-webpack-plugin": "4.2.2",
    "html-webpack-plugin": "5.5.0",
    "http-server": "14.1.1",
    "mini-css-extract-plugin": "2.7.0",
    "msw": "0.49.0",
    "node-sass": "8.0.0",
    "npm-check-updates": "16.4.1",
    "pre-commit": "1.2.2",
    "prettier": "2.7.1",
    "sass-loader": "13.2.0",
    "style-loader": "3.3.1",
    "terser-webpack-plugin": "5.3.6",
    "ts-loader": "9.4.1",
    "ts-node": "10.9.1",
    "typescript": "4.9.3",
    "webpack": "5.75.0",
    "webpack-cli": "5.0.0",
    "webpack-dev-server": "4.11.1"
  }
}
